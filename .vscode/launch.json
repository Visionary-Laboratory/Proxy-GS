{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Train (Debug)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/train.py",
            "console": "integratedTerminal",
            "justMyCode": false,
            "args": [
                "-s", "proxy-gs/small_city/camera_calibration/aligned",
                "-i", "proxy-gs/small_city/camera_calibration/rectified/images",
                "-m", "output_demo/small_city",
                "--ply_mesh", "proxy-gs/small_city/camera_calibration/small_city_fixed.ply",
            ],
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        },
        {
            "name": "Python: Train (Normal)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/train.py",
            "console": "integratedTerminal",
            "justMyCode": false,
            "args": [
                "-s", "proxy-gs/campus/camera_calibration/chunks/1_1",
                "-i", "proxy-gs/campus/camera_calibration/rectified/images",
                "-m", "output/campus_1_1_ours_add_1",
                "--ply_mesh", "proxy-gs/campus/agg_1.ply",
                "--ratio", "2"
            ],
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        },
        {
            "name": "Python: Render Real",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/render_real.py",
            "console": "integratedTerminal",
            "justMyCode": false,
            "args": [
                "-m", "output_demo/small_city",
                "--iteration", "-1",
                "--render_video"
            ],
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        },
        {
            "name": "Python: Mesh Render Block E",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/mesh_render.py",
            "console": "integratedTerminal",
            "justMyCode": false,
            "args": [
                "-s", "proxy-gs/MatrixCity/small_city/street/pose/block_E",
                "-m", "output",
                "-i", "proxy-gs/MatrixCity/small_city/street/train/small_city_road_horizon",
                "--ply_mesh", "cvpr/block_E_from_mesh.ply",
                "--depth_npy_dir", "mesh_depth_block_E"
            ],
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        },
        {
            "name": "Python: Train Block E",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/train.py",
            "console": "integratedTerminal",
            "justMyCode": false,
            "args": [
                "-s", "proxy-gs/MatrixCity/small_city/street/pose/block_E",
                "-m", "output",
                "-i", "proxy-gs/MatrixCity/small_city/street/train/small_city_road_horizon",
                "--ply_mesh", "cvpr/block_E_from_mesh.ply",
                "--depth_npy_dir", "mesh_depth_block_E",
                "--ply_path", "proxy-gs/MatrixCity/small_city/street/pose/block_E/points3d.ply"
            ],
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        }
    ]
}
